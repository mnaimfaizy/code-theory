# Database
# Local development defaults to SQLite.
# For production or cPanel, set DATABASE_URL to a postgres:// or postgresql:// URL instead.
DATABASE_URL=file:./data/code-theory.db
# DATABASE_URL=postgres://user:password@host:5432/code_theory

# Auth
AUTH_SECRET=change-me-to-a-random-string
AUTH_URL=http://localhost:3000

# Local LLM (for question generation)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3
LLM_API_KEY=ollama
