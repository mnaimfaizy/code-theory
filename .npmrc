# Keep direct dependencies pinned to the exact versions that were reviewed.
save-exact=true

# Always keep a lockfile for reproducible installs.
package-lock=true

# Surface known advisories during local npm operations.
audit=true

# Delay new package releases for 14 days before they can be selected.
min-release-age=14

# Prefer a deduped tree when npm can do so safely.
prefer-dedupe=true

# Do not set ignore-scripts=true globally in this repo.
# The current toolchain still depends on reviewed install scripts from
# better-sqlite3, sharp, esbuild, and related native wrappers.
# Use npm ci --ignore-scripts only for disposable review flows.